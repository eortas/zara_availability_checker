# ==========================================
# CONFIGURACIÓN DEL BOT DE TELEGRAM
# ==========================================
# Token del bot (se obtiene vía @BotFather en Telegram)
TELEGRAM_TOKEN=TU_TOKEN_AQUI

# Tu Chat ID (se obtiene enviando un mensaje a @userinfobot en Telegram)
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI

# ==========================================
# CONFIGURACIÓN DEL PRODUCTO DE ZARA
# ==========================================
# URL completa del producto (la que ves en el navegador)
ZARA_PRODUCT_URL=https://www.zara.com/es/es/zueco-piel-hebilla-p12721620.html?v1=495716335

# Talla que quieres monitorizar
TALLA_BUSCADA=42

# Intervalo entre comprobaciones en segundos (300 = 5 minutos)
INTERVALO=300
